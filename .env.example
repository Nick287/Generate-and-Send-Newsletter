# =============================================================================
# AI Weekly Digest — environment variables
# Compatible with both newsletter_git_action.py and run_pipeline.py
# 兼容 newsletter_git_action.py 和 run_pipeline.py
# Copy to .env and fill in your values. .env is gitignored.
# =============================================================================

# ---- SMTP Email Settings | SMTP邮件设置 ------------------------------------
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SENDER_USERNAME=your-email@example.com
SENDER_PASSWORD=your-password
TO_ADDRS=recipient@example.com
FROM_ALIAS=Bo News Agent

# ---- Azure OpenAI | Azure OpenAI设置 ----------------------------------------
AZURE_OPENAI_TOKEN=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# ---- Alternative: standard OpenAI (uncomment if not using Azure) -------------
# OPENAI_API_KEY=sk-...
# LLM_API_KEY=sk-...
